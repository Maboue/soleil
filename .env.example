VITE_CONVEX_URL=https://your-deployment.convex.cloud
# App URL for OAuth redirects / magic links (set on the Convex deployment).
# JWT issuer is CONVEX_SITE_URL (usually auto-set by Convex); convex/auth.config.ts
# uses that for `domain` so tokens validate — do not point `domain` at localhost unless
# that is actually your deployment issuer.
SITE_URL=http://localhost:5173
#
# Convex Auth requires these on EVERY deployment (dev + prod). If sign-in fails with
# Missing JWT_PRIVATE_KEY, run the setup CLI and pick the right deployment:
#   npx @convex-dev/auth              # dev (default)
#   npx @convex-dev/auth --prod       # production
# That sets SITE_URL, JWT_PRIVATE_KEY, and JWKS on the backend. You can also paste
# the same three vars in Dashboard → Settings → Environment Variables.
#
# Two editors: footer Admin → Create account once per person; Data → users → isAdmin = true on both.
# Replacing a login: delete that user in Data, then: npx convex run internal.userCleanup.sweepOrphanedAuth '{}'
#
# Contact form (Convex backend env — Dashboard → Settings → Environment Variables, not .env):
#   RESEND_API_KEY=re_...
#   CONTACT_TO_EMAIL=you@example.com
# Optional if you verified a domain in Resend:
#   CONTACT_FROM=Your Name <hello@yourdomain.com>
